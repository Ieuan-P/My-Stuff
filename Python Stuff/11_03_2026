import random
# Constants
ITERATE = 30
BOTTOM = 1
TOP = 100

# Variables
NUMBERS = []
TWO = []
THREE = []
FIVE = []
SEVEN = []

# Program
while len(NUMBERS) < ITERATE:
    attempt = random.randint(BOTTOM, TOP)
    if attempt not in NUMBERS:
        NUMBERS.append(attempt)

for num in NUMBERS:
    if num % 2 == 0:
        TWO.append(str(num))
    if num % 3 == 0:
        THREE.append(str(num))
    if num % 5 == 0:
       FIVE.append(str(num))
    if num % 7 == 0:
        SEVEN.append(str(num))

